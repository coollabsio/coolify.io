---
const target = "/services";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Services | Coolify</title>
    <link rel="canonical" href="https://coolify.io/services/" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <script is:inline>
      window.location.replace("/services");
    </script>
  </head>
  <body style="font-family: Inter, sans-serif; background: #101010; color: white; padding: 2rem;">
    <p>
      This page moved to <a href={target} style="color: #fcd34d;">/services</a>.
    </p>
  </body>
</html>
