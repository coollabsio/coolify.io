---
import Layout from "../layouts/Layout.astro";
import Integrations from "../components/Integrations.svelte";
---

<Layout
  title="Integrations | Coolify"
  canonicalUrl="https://coolify.io/integrations/"
  description="Browse 320+ one-click services you can self-host with Coolify. Databases, CMS, monitoring, AI, dev tools, and more."
>
  <h1 class="text-3xl font-bold tracking-tight text-white md:text-6xl px-4">
    Integrations<span class="text-warning">.</span>
  </h1>
  <h2 class="text-base pb-10 pt-2 text-neutral-400 px-4">
    320+ one-click services ready to deploy on your own servers.
  </h2>
  <Integrations client:load />
</Layout>
