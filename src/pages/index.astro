---
import Layout from "../layouts/Layout.astro";
import Instances from "../components/Instances.svelte";
import HugeSponsors from "../components/HugeSponsors.svelte";
import BigSponsors from "../components/BigSponsors.svelte";
import SmallSponsors from "../components/SmallSponsors.svelte";
import SponsorsPreview from "../components/SponsorsPreview.svelte";

const isDev = import.meta.env.DEV;
---

<Layout
  title="Coolify"
  canonicalUrl="https://coolify.io/"
  description="Self-hosting platform with superpowers. Deploy apps, databases & 280+ services to your server. Open-source alternative to Heroku."
>
  <h1 class="text-3xl font-bold tracking-tight text-white md:text-6xl px-4">
    Self-hosting with superpowers<span class="text-warning">.</span>
  </h1>
  <h2 class="text-base pt-4 text-neutral-400 px-4 max-w-4xl mx-auto">
    An open-source & self-hostable alternative to Vercel, Heroku, Netlify and
    Railway for easily deploying websites, databases, web applications and 280+
    one-click services to your own server.
  </h2>
  <p>Open source & free forever, backed by <a class="underline" href="/philosophy">our philosophy</a>.</p>
  <div class="pb-10 pt-4 text-xs flex gap-2 justify-center flex-row flex-wrap">
    <a
      class="hover:underline cursor-pointer text-white flex gap-2 items-center justify-center"
      target="_blank"
      href="https://coolify.io/docs/get-started/screenshots"
      ><i class="ph-duotone ph-camera text-warning text-xl" aria-hidden="true"></i>Screenshots</a
    >
    <a
      class="hover:underline cursor-pointer text-white flex gap-2 items-center justify-center"
      target="_blank"
      href="https://coolify.io/docs/get-started/videos"
    >
      <i class="ph-duotone ph-video text-warning text-xl" aria-hidden="true"></i>
      Videos</a
    >
    <a
      class="hover:underline cursor-pointer text-white flex gap-2 items-center justify-center text-xs"
      target="_blank"
      href="https://twitch.tv/heyandras"
    >
      <i class="ph-duotone ph-twitch-logo text-purple-500 text-base" aria-hidden="true"></i>

      Building in live-streams</a
    >
  </div>
  <div class="pb-2 flex justify-center text-center gap-8 px-4">
    <div>
      <a
        href="/cloud"
        class="text-xs sm:text-base font-bold rounded p-4 px-2 text-white bg-coolgray-300 hover:bg-coolgray-400 flex gap-2 lg:w-64 justify-center"
        ><i class="ph-duotone ph-cloud text-warning text-xl" aria-hidden="true"></i>Cloud</a
      >
      <div
        class="text-neutral-400 sm:text-base text-xs sm:flex-row flex flex-col gap-1 pt-2 sm:justify-center"
      >
        <span class="text-warning mt-[0.1rem] font-bold font-mono"
          ><span id="cloud-users">3,641</span>+</span
        > customers in the cloud.
      </div>
    </div>
    <div>
      <a
        href="/self-hosted"
        class="text-xs sm:text-base font-bold rounded p-4 px-2 text-white bg-coolgray-300 hover:bg-coolgray-400 flex gap-2 lg:w-64 justify-center"
        ><i class="ph-duotone ph-hard-drives text-warning text-xl" aria-hidden="true"></i>Self-hosted</a
      >
      <Instances client:load />
    </div>
  </div>
  <div id="sponsors-section">
    <HugeSponsors client:only="svelte" />
    <BigSponsors client:only="svelte" />
    <SmallSponsors client:only="svelte" />
    {isDev && <SponsorsPreview client:only="svelte" />}
  </div>

  <div id="features" class="text-center text-4xl font-bold pt-10 text-white scroll-mt-20">
    Features
  </div>
  <div
    class="mx-auto mt-16 max-w-2xl sm:mt-14 lg:mt-14 lg:max-w-none text-left"
  >
    <dl
      class="grid max-w-xl grid-cols-1 gap-x-8 px-4 gap-y-16 lg:max-w-none lg:grid-cols-3"
    >
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-code text-warning text-2xl" aria-hidden="true"></i>
          Any Language
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Coolify is compatible with a wide range of programming languages and
            frameworks, enabling you to launch static websites, APIs, backends,
            databases, services, and other types of applications.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-hard-drives text-warning text-2xl" aria-hidden="true"></i>
          Any Server
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            You can deploy your resources to any server, including your own
            servers, VPS, Raspberry Pi, EC2, DigitalOcean, Linode, Hetzner, and
            more. All you need is an SSH connection.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-text-aa text-warning text-2xl" aria-hidden="true"></i>
          Any Use-Case
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            You can deploy your resources (apps, databases, services) to a
            single server or multiple servers according to your requirements.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-plugs text-warning text-2xl" aria-hidden="true"></i>
          Any Service
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            You can deploy any service you want that is compatible with Docker.
            Also there are lots of one-click services available to deploy. <br
            />See the full list <a
              class="text-warning underline"
              href="https://coolify.io/docs/services/overview?utm_source=coolify.io"
              >here</a
            >.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-git-branch text-warning text-2xl" aria-hidden="true"></i>
          Push to deploy
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Nowadays, Git integration is considered the norm. We provide
            integration with both hosted and self-hosted platforms like GitHub,
            GitLab, Bitbucket, Gitea, and others.
          </p>
        </dd>
      </div>

      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-lock-key text-warning text-2xl" aria-hidden="true"></i>
          Free SSL Certificates
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Coolify takes care of automatically setting up and renewing Let's
            Encrypt SSL certificates for your custom domains, so you can relax
            and not have to deal with it.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-lock-open text-warning text-2xl" aria-hidden="true"></i>
          No vendor lock-in
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            You have complete control over your data. All settings are saved on
            your own servers, giving you the ability to oversee everything even
            if you decide to stop using Coolify (oh nooo).
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-database text-warning text-2xl" aria-hidden="true"></i>
          Automatic DB Backups
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Your data is automatically backed up to any S3 compatible solution,
            allowing you to easily restore it with just a few clicks if any
            problems occur.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-webhooks-logo text-warning text-2xl" aria-hidden="true"></i>
          Webhooks
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Integrate into your CI/CD pipelines or create custom integrations
            using Github Actions, Gitlab CI, Bitbucket Pipelines, or any other
            CI/CD tool of your choice.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-code text-warning text-2xl" aria-hidden="true"></i>
          Powerful API
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Coolify offers a robust API that enables you to automate
            deployments, manage resources, and integrate with your current
            tools, providing limitless possibilities.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-terminal-window text-warning text-2xl" aria-hidden="true"></i>

          Real-time Terminal
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            You do not need to leave your browser to manage your servers.
            Coolify's real-time terminal allows you to run commands on your
            servers directly from your browser.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-users-three text-warning text-2xl" aria-hidden="true"></i>
          Collaborative
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Share your projects with your team members and work together on
            them. You can also control permissions and roles for each member.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-git-pull-request text-warning text-2xl" aria-hidden="true"></i>
          Pull Request Deployments
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Automagically deploy new commits and pull requests separately to
            quickly review contributions and speed up your teamwork!
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-robot text-warning text-2xl" aria-hidden="true"></i>
          Server Automations
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Once your server is connected, Coolify will handle numerous tasks
            automatically, allowing you to concentrate on your code.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-chart-line-up text-warning text-2xl" aria-hidden="true"></i>
          Monitoring
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Coolify will keep an eye on your deployments, servers, disk usage,
            and other aspects, and notify you if any issues arise.
          </p>
        </dd>
      </div>
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <i class="ph-duotone ph-bell-ringing text-warning text-2xl" aria-hidden="true"></i>
          Notifications
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Coolify will notify you through your chosen channels like Discord,
            Telegram, and email in case of any events on your server or with
            your deployments.
          </p>
        </dd>
      </div>
    </dl>
  </div>
  <!-- Skip to Features Button -->
  <a
    href="#features"
    id="skip-to-features"
    class="fixed bottom-4 right-4 bg-coollabs hover:bg-coollabs/80 text-white px-3 py-2 rounded-full shadow-lg transition-all duration-300 text-xs font-medium z-50 flex items-center gap-2"
    aria-label="Skip to Features section"
  >
    <span class="hidden sm:inline">Jump to Features</span>
    <span class="sm:hidden">Jump to Features</span>
  </a>
  <script>
    fetch("https://cdn.coollabs.io/business.json")
      .then((res) => res.json())
      .then((data) => {
        const cloudUsersEl = document.getElementById("cloud-users");
        if (cloudUsersEl && data["coolify-cloud-users"]) {
          cloudUsersEl.textContent =
            data["coolify-cloud-users"].toLocaleString();
        }
      })
      .catch(() => {});

    // Smooth scroll for skip to features button
    const skipButton = document.getElementById("skip-to-features");
    skipButton?.addEventListener("click", (e) => {
      e.preventDefault();
      const targetElement = document.getElementById("features");
      if (targetElement) {
        targetElement.scrollIntoView({
          behavior: "smooth",
          block: "start",
        });
      }
    });
  </script>
</Layout>
