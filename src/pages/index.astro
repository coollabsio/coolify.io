---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Home/Hero.astro";
import FeatureCard from "../components/Home/FeatureCard.astro";
import HomeServicesCard from "../components/Home/HomeServicesCard.astro";
import BoomStats from "../components/Home/BoomStats.svelte";
import HugeSponsors from "../components/HugeSponsors.svelte";
import BigSponsors from "../components/BigSponsors.svelte";
import SmallSponsors from "../components/SmallSponsors.svelte";
import SponsorsPreview from "../components/SponsorsPreview.svelte";
import FloatingNav from "../components/Home/FloatingNav.svelte";
import { homeFeatures } from "../data/homeFeatures";
import IconDatabaseBackup from "../components/Icons/IconDatabaseBackup.svelte";
import IconCode from "../components/Icons/IconCode.svelte";
import IconMonitoring from "../components/Icons/IconMonitoring.svelte";
import IconRobot from "../components/Icons/IconRobot.svelte";
import IconAutomations from "../components/Icons/IconAutomations.svelte";
import IconCommunity from "../components/Icons/IconCommunity.svelte";
import IconPullRequest from "../components/Icons/IconPullRequest.svelte";
import IconTerminalWindow from "../components/Icons/IconTerminalWindow.svelte";
import IconApi from "../components/Icons/IconApi.svelte";
import IconLockCheck from "../components/Icons/IconLockCheck.svelte";
import IconServerFeature from "../components/Icons/IconServerFeature.svelte";
import IconNotifications from "../components/Icons/IconNotifications.svelte";

const isDev = import.meta.env.DEV;

const services = [
  { title: "Databases", description: "MySQL, PostgreSQL, MongoDB, Redis, MariaDB, and more. Deploy production databases in one click.", icon: IconDatabaseBackup },
  { title: "CMS", description: "WordPress, Ghost, Strapi, Directus, Plausible, and 20+ content platforms ready to deploy.", icon: IconCode },
  { title: "Monitoring", description: "Grafana, Prometheus, Uptime Kuma, Sentry, Metabase, and observability tools for your stack.", icon: IconMonitoring },
  { title: "AI & ML", description: "Ollama, LocalAI, Open WebUI, and AI infrastructure to run models on your own hardware.", icon: IconRobot },
  { title: "Automation", description: "n8n, Activepieces, Dagu, Huginn, and workflow engines to automate everything.", icon: IconAutomations },
  { title: "Communication", description: "Mattermost, Rocket.Chat, Nextcloud Talk, and team collaboration platforms.", icon: IconCommunity },
  { title: "CI/CD", description: "GitLab Runner, Jenkins, Woodpecker, and continuous deployment pipelines.", icon: IconPullRequest },
  { title: "Dev Tools", description: "VSCode Server, code-server, GitLab, Supabase, PocketBase, and developer platforms.", icon: IconTerminalWindow },
  { title: "Analytics", description: "Plausible, Matomo, Umami, Fathom, and privacy-first analytics solutions.", icon: IconApi },
  { title: "Security", description: "Vaultwarden, Authelia, Authentik, and identity & access management tools.", icon: IconLockCheck },
  { title: "Storage", description: "MinIO, Nextcloud, Seafile, and file sync & object storage platforms.", icon: IconServerFeature },
  { title: "Notifications", description: "Gotify, Ntfy, Novu, and real-time notification infrastructure.", icon: IconNotifications },
];
---

<Layout
  title="Coolify"
  canonicalUrl="https://coolify.io/"
  description="Self-hosting platform with superpowers. Deploy apps, databases & 280+ services to your server. Open-source alternative to Heroku."
>
  <Hero isDev={isDev} />

  <!-- Features -->
  <section id="features" class="px-4 pt-20 md:pt-28 scroll-mt-24 reveal">
    <div class="text-center">
      <span class="inline-block text-xs font-semibold tracking-widest uppercase text-warning mb-3">Platform</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
        Everything you need to ship<span class="text-warning">.</span>
      </h2>
      <p class="mt-3 text-sm md:text-base text-neutral-400 max-w-2xl mx-auto leading-relaxed">
        From deployment to monitoring — Coolify handles the infrastructure so you can focus on building.
      </p>
    </div>
    <div
      class="mx-auto mt-12 lg:mt-12 text-left"
    >
      <dl
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-5 gap-y-6 lg:gap-x-6 lg:gap-y-8 reveal-children"
      >
        {homeFeatures.map((feature) => <FeatureCard {...feature} />)}
      </dl>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="px-4 pt-20 md:pt-28 scroll-mt-24 reveal">
    <div class="text-center">
      <span class="inline-block text-xs font-semibold tracking-widest uppercase text-warning mb-3">One-Click Services</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
        280+ services at your fingertips<span class="text-warning">.</span>
      </h2>
      <p class="mt-3 text-sm md:text-base text-neutral-400 max-w-2xl mx-auto leading-relaxed">
        Deploy databases, CMS platforms, monitoring tools, and more with a single click. No configuration headaches.
      </p>
    </div>

    <div class="mx-auto mt-12 max-w-6xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 reveal-children">
        {services.map((service) => <HomeServicesCard {...service} />)}
      </div>
    </div>

    <div class="text-center mt-10">
      <a
        href="/services"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white bg-white/5 border border-white/10 hover:bg-white/10 hover:border-warning/30 transition-all duration-200 group"
      >
        Explore all services
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Sponsors -->
  <section id="sponsors" class="px-4 pt-20 md:pt-28 reveal">
    <div class="text-center">
      <span class="inline-block text-xs font-semibold tracking-widest uppercase text-warning mb-3">Supported By</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
        Backed by the best<span class="text-warning">.</span>
      </h2>
      <p class="mt-3 text-sm md:text-base text-neutral-400 max-w-2xl mx-auto leading-relaxed">
        Our sponsors make open-source development sustainable. Join them in supporting Coolify.
      </p>
    </div>
    <div id="sponsors-section" class="mt-12">
      <HugeSponsors client:only="svelte" />
      <BigSponsors client:only="svelte" />
      <SmallSponsors client:only="svelte" />
      {isDev && (
        <SponsorsPreview client:only="svelte" />
      )}
    </div>
  </section>

  <BoomStats client:visible />

  <FloatingNav client:only="svelte" />
</Layout>