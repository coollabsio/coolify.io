---
import Layout from "../layouts/Layout.astro";
import { marked } from "marked";

marked.setOptions({
  gfm: true,
});

const githubToken = import.meta.env.GITHUB_TOKEN ?? process.env.GITHUB_TOKEN;

const headers: Record<string, string> = {
  Accept: "application/vnd.github+json",
  "User-Agent": "coolify-landing",
};

if (githubToken) {
  headers.Authorization = `Bearer ${githubToken}`;
}

let releases: any[] = [];

try {
  const response = await fetch("https://api.github.com/repos/coollabsio/coolify/releases", {
    headers,
  });

  if (response.ok) {
    const data = await response.json();
    releases = Array.isArray(data) ? data : [];
  }
} catch {
  releases = [];
}

const parsedReleases = await Promise.all(
  releases.map(async (release: any) => ({
    name: release.name || release.tag_name,
    tag: release.tag_name,
    date: release.published_at || release.created_at,
    url: release.html_url,
    body: await marked.parse(release.body || ""),
  })),
);
---

<Layout
  title="Changelog | Coolify"
  canonicalUrl="https://coolify.io/changelog/"
  description="Latest Coolify releases and updates from the GitHub repository."
>
  <section class="max-w-3xl mx-auto px-4 pb-16">
    <div class="mb-12">
      <h1 class="text-3xl font-bold tracking-tight text-white md:text-6xl">
        Changelog<span class="text-warning">.</span>
      </h1>
      <p class="pt-2 text-base text-neutral-400">
        Latest releases from the <a
          href="https://github.com/coollabsio/coolify"
          class="text-warning hover:underline"
          target="_blank"
          rel="noopener"
        >
          GitHub repository
        </a>.
      </p>
    </div>

    <div class="space-y-12 text-left">
      {parsedReleases.length === 0 && (
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-center text-neutral-400">
          Unable to load releases right now.
        </div>
      )}

      {parsedReleases.map((release: any) => (
        <article class="relative border-l-2 border-warning pl-6">
          <div class="absolute -left-[7px] top-1 h-3 w-3 rounded-full bg-warning"></div>

          <div class="mb-3 flex flex-wrap items-baseline gap-3">
            <a
              href={release.url}
              target="_blank"
              rel="noopener"
              class="text-xl font-semibold text-white transition-colors hover:text-warning md:text-2xl"
            >
              {release.name}
            </a>
            {release.tag && release.tag !== release.name && (
              <code class="rounded bg-coolgray-300 px-2 py-1 text-xs text-neutral-300">
                {release.tag}
              </code>
            )}
            {release.date && (
              <time class="text-sm text-neutral-500">
                {new Date(release.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            )}
          </div>

          <div
            class="prose prose-invert prose-sm max-w-none
            prose-headings:mb-3 prose-headings:mt-5 prose-headings:font-semibold prose-headings:text-white
            prose-h2:text-xl prose-h3:text-lg
            prose-p:leading-relaxed prose-p:text-neutral-300
            prose-a:text-warning prose-a:no-underline hover:prose-a:underline
            prose-strong:text-white
            prose-ul:list-disc prose-ul:pl-6 prose-ul:space-y-1
            prose-ol:list-decimal prose-ol:pl-6 prose-ol:space-y-1
            prose-li:text-neutral-300 marker:text-warning
            prose-code:rounded prose-code:bg-neutral-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-neutral-200
            prose-pre:border prose-pre:border-white/10 prose-pre:bg-neutral-900
            prose-blockquote:border-warning/40 prose-blockquote:text-neutral-300
            prose-hr:border-white/10"
            set:html={release.body}
          />
        </article>
      ))}
    </div>
  </section>
</Layout>
