---
import IconDatabaseBackup from "../Icons/IconDatabaseBackup.svelte";
import IconCode from "../Icons/IconCode.svelte";
import IconMonitoring from "../Icons/IconMonitoring.svelte";
import IconRobot from "../Icons/IconRobot.svelte";
import IconAutomations from "../Icons/IconAutomations.svelte";
import IconCommunity from "../Icons/IconCommunity.svelte";
import IconPullRequest from "../Icons/IconPullRequest.svelte";
import IconTerminalWindow from "../Icons/IconTerminalWindow.svelte";
import IconApi from "../Icons/IconApi.svelte";
import IconLockCheck from "../Icons/IconLockCheck.svelte";
import IconServerFeature from "../Icons/IconServerFeature.svelte";
import IconNotifications from "../Icons/IconNotifications.svelte";

export type Props = {
  title: string;
  description: string;
  icon: any;
};

const { title, description, icon: Icon } = Astro.props;
---

<div class="service-card group relative overflow-hidden rounded-2xl p-5 flex flex-col cursor-default">
  <div class="card-noise"></div>
  <div class="card-spotlight"></div>

  <div class="relative z-10 flex items-center gap-3">
    <span class="icon-wrapper">
      <Icon class="service-icon text-warning" aria-hidden="true" />
    </span>
    <h3 class="text-base font-semibold text-white/90 group-hover:text-white transition-colors duration-300">
      {title}
    </h3>
  </div>

  <p class="relative z-10 mt-2.5 text-sm leading-relaxed text-neutral-500 group-hover:text-neutral-400 transition-colors duration-300">
    {description}
  </p>
</div>

<style>
  .service-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04), inset 0 -1px 0 rgba(255, 255, 255, 0.02);
    transition: transform 0.3s cubic-bezier(0.22, 0.61, 0.36, 1), border-color 0.3s ease, background 0.3s ease;
  }

  .service-card:hover {
    border-color: rgba(252, 211, 77, 0.25);
    background: rgba(252, 211, 77, 0.04);
    box-shadow: inset 0 1px 0 rgba(252, 211, 77, 0.1), inset 0 -1px 0 rgba(252, 211, 77, 0.05), 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(252, 211, 77, 0.08);
    border: 1px solid rgba(252, 211, 77, 0.12);
    flex-shrink: 0;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    box-shadow: inset 0 1px 0 rgba(252, 211, 77, 0.08);
  }

  .group:hover .icon-wrapper {
    background: rgba(252, 211, 77, 0.14);
    border-color: rgba(252, 211, 77, 0.25);
    box-shadow: inset 0 1px 0 rgba(252, 211, 77, 0.15), 0 0 16px rgba(252, 211, 77, 0.1);
  }

  .service-icon {
    width: 18px;
    height: 18px;
  }

  .card-noise {
    position: absolute;
    inset: 0;
    opacity: 0.25;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.5'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  .card-spotlight {
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at top right, rgba(252, 211, 77, 0.04), transparent 70%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .group:hover .card-spotlight {
    opacity: 1;
  }
</style>