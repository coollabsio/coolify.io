---
export type FeatureLink = {
  href: string;
  text: string;
  before?: string;
  after?: string;
};

export type Props = {
  title: string;
  description: string;
  Icon: any;
  titleHref?: string;
  descriptionLink?: FeatureLink;
};

const {
  title,
  description,
  Icon,
  titleHref,
  descriptionLink
} = Astro.props;
---

<div
  class="feature-card group relative overflow-hidden rounded-2xl p-6 flex flex-col cursor-default"
>
  <div class="card-noise"></div>

  <!-- right top grid texture -->
  <div class="grid-texture"></div>

  <!-- left border -->
  <div class="feature-border">
      <span class="border-indicator"></span>
  </div>

  <dt class="relative z-10 flex items-center gap-x-3 text-xl">

    <span
      class="flex h-9 w-9 items-center justify-center rounded-md bg-warning/15
      transition-all duration-300
      group-hover:bg-warning"
    >
      <Icon
        class="icon text-white
        transition-all duration-300
        group-hover:text-black"
        aria-hidden="true"
      />
    </span>

    {titleHref ? (
      <a
        href={titleHref}
        target="_blank"
        rel="noopener noreferrer"
        class="
        text-white/90
        underline
        decoration-warning
        decoration-2
        underline-offset-4
        transition-all
        duration-300
        hover:text-warning"
      >
        {title}
      </a>
    ) : (
      <span
        class="
        text-white/90
        transition-all
        duration-300
        group-hover:text-white"
      >
        {title}
      </span>
    )}

  </dt>

  <dd
    class="
    relative z-10
    mt-4
    flex-auto
    text-sm
    leading-6
    text-neutral-400
    transition-colors
    duration-300
    group-hover:text-neutral-300"
  >
    <p>

      {description}

      {descriptionLink && (
        <>
          <br />

          {descriptionLink.before}

          <a
            class="text-warning underline"
            href={descriptionLink.href}
          >
            {descriptionLink.text}
          </a>

          {descriptionLink.after}
        </>
      )}

    </p>

  </dd>

</div>

<style>

.feature-card{

background:
rgba(255,255,255,.02);

border:
1px solid rgba(255,255,255,.05);

backdrop-filter:
blur(12px);

box-shadow:
inset 0 1px 0 rgba(255,255,255,.04),
inset 0 -1px 0 rgba(255,255,255,.02);

transition:
transform .35s cubic-bezier(.22,.61,.36,1),
border-color .35s ease,
background .35s ease;
}


.feature-card:hover{

transform:
translateY(-2px);

border-color:
rgba(255,220,0,.25);

background:
rgba(255,255,255,.035);

box-shadow:
inset 0 1px 0 rgba(255,220,0,.06),
inset 0 -1px 0 rgba(255,220,0,.03),
0 6px 20px rgba(0,0,0,.15);
}


/* left border */

.feature-border{

position:absolute;

left:0;
top:10%;
bottom:10%;

width:1px;

background:
rgba(180,180,180,.2);

overflow:hidden;
}


/* center yellow indicator */

.border-indicator{

position:absolute;

left:0;

top:50%;

transform:
translateY(-50%);

width:100%;
height:34px;

border-radius:999px;

background:
linear-gradient(
to bottom,
rgba(255,220,0,.15),
rgba(255,220,0,.7),
rgba(255,220,0,.15)
);

transition:
height .4s ease,
background .4s ease;
}


.group:hover .border-indicator{

height:100%;

background:
linear-gradient(
to bottom,
#FFD000,
#FACC15,
#FFD000
);
}


/* right top grid texture */

.grid-texture{

position:absolute;

top:0;
right:0;

width:150px;
height:150px;

opacity:.45;

background-image:

linear-gradient(
  rgba(252, 211, 77, 0.35) 1px,
  transparent 1px
),

linear-gradient(
  90deg,
  rgba(252, 211, 77, 0.35) 1px,
  transparent 1px
);

background-size:
18px 18px;


/* fade toward center */

mask-image:
radial-gradient(
circle at top right,
black 25%,
transparent 75%
);

-webkit-mask-image:
radial-gradient(
circle at top right,
black 25%,
transparent 75%
);

pointer-events:none;
}

.card-noise {
  position: absolute;
  inset: 0;
  opacity: 0.15;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.5'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 128px 128px;
  pointer-events: none;
  mix-blend-mode: overlay;
}

</style>