---
import IconX from "./Icons/IconX.svelte";
import IconGitHub from "./Icons/IconGitHub.svelte";
import IconDiscord from "./Icons/IconDiscord.svelte";
---

<footer class="mt-24 border-t border-coolgray-300/20 relative overflow-hidden">

    <!-- background glow -->
    <div
        class="absolute inset-x-0 bottom-0 h-[350px]
        bg-gradient-to-t
        from-purple-500/10
        via-violet-500/5
        to-transparent
        blur-3xl pointer-events-none"
    />

    <div class="mx-auto max-w-7xl px-6 py-16 relative z-10">

        <!-- Top footer -->
        <div
            class="grid grid-cols-1
            sm:grid-cols-2
            lg:grid-cols-3
            gap-12"
        >

            <!-- About -->
            <div class="space-y-4 text-center">
                <h3 class="text-lg font-semibold">
                    About
                </h3>

                <p class="text-sm text-neutral-400 leading-relaxed">
                    Coolify is an open-source platform helping developers
                    deploy applications, databases and services with a
                    modern self-hosted experience.
                </p>
            </div>

            <!-- Links -->
            <div class="space-y-4 text-center">
                <h3 class="text-lg font-semibold">
                    Links
                </h3>

                <div class="flex flex-col gap-3 items-center">

                    <a
                        href="https://coollabs.io"
                        target="_blank"
                        class="footer-link"
                    >
                        Other Projects
                    </a>

                    <a
                        href="https://coollabs.io/privacy-policy/"
                        target="_blank"
                        class="footer-link"
                    >
                        Privacy Policy
                    </a>

                    <a
                        href="https://coollabs.io/terms-of-service"
                        target="_blank"
                        class="footer-link"
                    >
                        Terms of Service
                    </a>

                    <a
                        href="https://coollabs.io/refund-policy/"
                        target="_blank"
                        class="footer-link"
                    >
                        Refund Policy
                    </a>

                </div>
            </div>


            <!-- Connect -->
            <div class="space-y-4 text-center">

                <h3 class="text-lg font-semibold">
                    Connect
                </h3>

                <div class="flex items-center justify-center gap-5">

                    <a
                        href="https://x.com/heyandras"
                        target="_blank"
                        aria-label="X"
                        class="social-icon"
                    >
                        <IconX class="h-5 w-5"/>
                    </a>

                    <a
                        href="https://github.com/coollabsio/coolify"
                        target="_blank"
                        aria-label="GitHub"
                        class="social-icon"
                    >
                        <IconGitHub class="h-5 w-5"/>
                    </a>

                    <a
                        href="https://coollabs.io/discord"
                        target="_blank"
                        aria-label="Discord"
                        class="social-icon"
                    >
                        <IconDiscord class="h-5 w-5"/>
                    </a>

                </div>
            </div>

        </div>


        <!-- Status badge -->
        <div class="flex justify-center mt-12">
            <span class="status-badge">
                <span class="status-dot" />
                All Systems Operational
            </span>
        </div>

        <!-- Huge title -->
        <div class="mt-16 relative">

            <h1
                class="
                coolify-title
                text-center
                font-black
                leading-none
                tracking-tight
                "
            >
                COOLIFY.IO
            </h1>

        </div>

        <!-- Credits -->
        <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-2 text-center">
            <p class="text-xs text-neutral-500">
                Built by <a href="https://x.com/heyandras" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-white transition-colors">Andras Bacsai</a>
            </p>
            <p class="text-xs text-neutral-500">
                &copy; 2026 coolLabs Solutions Kft. All rights reserved.
            </p>
        </div>

    </div>
</footer>

<style>
.footer-link{
    color:rgb(163 163 163);
    font-size:.95rem;

    transition:
    color .25s ease,
    transform .25s ease;
}

.footer-link:hover{
    color:white;
    transform:translateX(4px);
}

.social-icon{
    color:rgb(163 163 163);

    transition:
    transform .3s ease,
    color .3s ease;
}

.social-icon:hover{
    transform:
    translateY(-3px)
    scale(1.1);

    color:#a855f7;
}


/* Responsive huge title */

.coolify-title{

    font-size:
    clamp(
    3.5rem,
    14vw,
    11rem
    );

    background:
    linear-gradient(
        90deg,
        #c084fc,
        #8b5cf6,
        #6d28d9,
        #a855f7
    );

    background-size:200% auto;

    -webkit-background-clip:text;
    background-clip:text;
    color:transparent;

    opacity:.95;

    position:relative;
}


.status-badge{
    display:inline-flex;
    align-items:center;
    gap:0.5rem;
    padding:0.4rem 0.9rem;
    border-radius:999px;
    background:rgba(22 163 74 / 0.08);
    border:1px solid rgba(22 163 74 / 0.15);
    color:#4ade80;
    font-size:0.8rem;
    overflow:hidden;
}

.status-dot{
    width:10px;
    height:10px;
    border-radius:50%;
    background:#22c55e;
    flex-shrink:0;
    position:relative;
}

.status-dot::before{
    content:'';
    position:absolute;
    inset:-5px;
    border-radius:50%;
    border:2px solid rgba(34 197 94 / 0.25);
    animation:ripple-ring 2.5s ease-out infinite;
}

@keyframes ripple-ring{
    0%{transform:scale(1);opacity:0.35}
    100%{transform:scale(2);opacity:0}
}

/* faded glow behind text */

.coolify-title::after{

    content:"COOLIFY.IO";

    position:absolute;
    inset:0;

    z-index:-1;

    color:#8b5cf6;

    filter:blur(70px);

    opacity:.25;
}

</style>