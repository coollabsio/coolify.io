# Site URL for sitemap generation
SITE_URL=https://coolify.io

# GitHub Personal Access Token — CONTRIBUTORS
# Used by scripts/fetch-contributors.js (REST contributors endpoint).
# Without this token, the script is limited to 60 requests/hour.
# With a token, the limit increases to 5,000 requests/hour.
#
# Create:
# 1. https://github.com/settings/tokens
# 2. "Generate new token (classic)"
# 3. Scope: "public_repo" only
#
# For CI/CD: set GITHUB_TOKEN as an environment variable.
GITHUB_TOKEN=your_github_token_here

# GitHub Personal Access Token — SPONSORS (separate token, elevated scopes)
# Used by scripts/fetch-sponsors.js (Sponsors GraphQL API for coollabsio org).
# Kept separate from GITHUB_TOKEN because sponsors needs much higher privileges
# (financial tier visibility) and should not be reused for unrelated tasks.
#
# Requirements:
# - CLASSIC PAT (fine-grained PATs cannot read Sponsorship.tier — confirmed
#   via probe; fine-grained returns FORBIDDEN even with org admin rights).
# - Token user must be an admin of the coollabsio org.
# - Scopes:
#     - "admin:org"  (parent checkbox — read:org alone returns FORBIDDEN
#                     on tier.monthlyPriceInDollars)
#     - "read:user"  (sponsor entity profile data)
GITHUB_TOKEN_SPONSORS=your_sponsors_token_here
